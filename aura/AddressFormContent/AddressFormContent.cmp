    <!-- recordId present → edit existing record; absent → new record with Account pre-populated -->
    <lightning:recordForm objectApiName="Address__c" recordId="{!v.recordId}" layoutType="Full" columns="2" mode="edit"
        onsuccess="{!c.handleSuccess}" oncancel="{!c.handleCancel}" />

    <!-- ALTERNATIVE: split edit/new because lightning:recordForm does not support defaultFieldValues pre-population.
         Uncomment this block and remove the lightning:recordForm above if defaultFieldValues does not work.
